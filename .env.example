# Copy this file to .env and keep the real key local.
GROQ_API_KEY=replace-with-your-groq-api-key
AUDIENCE_TREND_MINER_MODEL=openai/gpt-oss-120b
DATABASE_URL=postgresql://localhost/audience_intelligence
AUDIENCE_TREND_MINER_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
AUDIENCE_TREND_MINER_EMBEDDING_BATCH_SIZE=32
AUDIENCE_TREND_MINER_SIMILARITY_THRESHOLD=0.62
