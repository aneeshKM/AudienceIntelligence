{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audienceintelligence.local/schemas/manifest.schema.json",
  "title": "Audience Trend Miner Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["as_of_argument", "as_of", "current_window", "previous_window", "configuration", "run_id", "status", "degraded", "failure_count", "failure_reasons"],
  "properties": {
    "as_of_argument": {"type": ["string", "null"], "format": "date"},
    "as_of": {"type": "string", "format": "date"},
    "current_window": {"$ref": "#/$defs/window"},
    "previous_window": {"$ref": "#/$defs/window"},
    "configuration": {"type": "object", "additionalProperties": {"type": "string"}},
    "run_id": {"type": ["string", "null"]},
    "status": {"enum": ["success", "degraded"]},
    "degraded": {"type": "boolean"},
    "failure_count": {"type": "integer", "minimum": 0},
    "failure_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {"start": {"type": "string", "format": "date"}, "end": {"type": "string", "format": "date"}}
    }
  }
}
