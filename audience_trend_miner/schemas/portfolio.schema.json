{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audienceintelligence.local/schemas/portfolio.schema.json",
  "title": "Emerging Audience Portfolio",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "as_of", "audiences"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "as_of": {"type": "string", "format": "date"},
    "audiences": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "estimated_size_index", "potential_buying_power"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "estimated_size_index": {"type": "number", "minimum": 0, "maximum": 100},
          "potential_buying_power": {"enum": ["high", "medium", "low"]}
        }
      }
    }
  }
}
