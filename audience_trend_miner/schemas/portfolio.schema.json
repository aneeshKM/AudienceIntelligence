{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audienceintelligence.local/schemas/portfolio.schema.json",
  "title": "Emerging Audience Portfolio",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "as_of", "status", "degraded", "failure_count", "failure_reasons", "audiences"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "as_of": {"type": "string", "format": "date"},
    "status": {"enum": ["success", "degraded"]},
    "degraded": {"type": "boolean"},
    "failure_count": {"type": "integer", "minimum": 0},
    "failure_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "audiences": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_component_id", "page_ids", "name", "description", "estimated_size_index", "potential_buying_power", "brand_categories", "buying_power_rationale", "buying_power_scores"],
        "properties": {
          "source_component_id": {"type": "integer", "minimum": 1},
          "page_ids": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
          "name": {"type": "string", "minLength": 3, "pattern": "^\\S+(?:\\s+\\S+){1,4}$"},
          "description": {"type": "string", "minLength": 1},
          "estimated_size_index": {"type": "number", "minimum": 0, "maximum": 100},
          "potential_buying_power": {"enum": ["high", "medium", "low"]},
          "brand_categories": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "buying_power_rationale": {"type": "string", "minLength": 1},
          "buying_power_scores": {
            "type": "object",
            "additionalProperties": false,
            "required": ["purchase_intent", "transaction_value", "category_breadth", "brand_safety"],
            "properties": {
              "purchase_intent": {"type": "integer", "minimum": 1, "maximum": 3},
              "transaction_value": {"type": "integer", "minimum": 1, "maximum": 3},
              "category_breadth": {"type": "integer", "minimum": 1, "maximum": 3},
              "brand_safety": {"type": "integer", "minimum": 1, "maximum": 3}
            }
          }
        }
      }
    }
  }
}
