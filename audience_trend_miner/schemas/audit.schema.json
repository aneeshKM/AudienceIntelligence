{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audienceintelligence.local/schemas/audit.schema.json",
  "title": "Audience Trend Miner Audit",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "degraded", "run", "decisions", "qualified_signals", "article_classifications", "candidate_clustering", "failures"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "status": {"enum": ["success", "failed"]},
    "degraded": {"type": "boolean"},
    "run": {"type": "object"},
    "decisions": {
      "type": "array",
      "items": {"$ref": "#/$defs/trendDecision"}
    },
    "qualified_signals": {
      "type": "array",
      "items": {"$ref": "#/$defs/qualifiedSignal"}
    },
    "article_classifications": {
      "type": "array",
      "items": {"$ref": "#/$defs/articleClassification"}
    },
    "candidate_clustering": {"$ref": "#/$defs/candidateClustering"},
    "failures": {
      "type": "array",
      "items": {"$ref": "#/$defs/failure"}
    },
    "raw_candidate_titles": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "canonical_articles": {
      "type": "array",
      "items": {"$ref": "#/$defs/canonicalArticle"}
    }
  },
  "$defs": {
    "semanticRepresentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_id", "canonical_title", "text", "embedding"],
      "properties": {
        "page_id": {"type": "integer", "minimum": 1},
        "canonical_title": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1},
        "embedding": {"type": "array", "minItems": 1, "items": {"type": "number"}}
      }
    },
    "similarity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["left_page_id", "right_page_id", "cosine_similarity"],
      "properties": {
        "left_page_id": {"type": "integer", "minimum": 1},
        "right_page_id": {"type": "integer", "minimum": 1},
        "cosine_similarity": {"type": "number", "minimum": -1, "maximum": 1}
      }
    },
    "candidateComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_id", "page_ids", "is_candidate_cluster"],
      "properties": {
        "component_id": {"type": "integer", "minimum": 1},
        "page_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
        "is_candidate_cluster": {"type": "boolean"}
      }
    },
    "candidateClustering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "threshold", "representations", "similarities", "edges", "components"],
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "threshold": {"type": "number", "minimum": -1, "maximum": 1},
        "representations": {"type": "array", "items": {"$ref": "#/$defs/semanticRepresentation"}},
        "similarities": {"type": "array", "items": {"$ref": "#/$defs/similarity"}},
        "edges": {"type": "array", "items": {"$ref": "#/$defs/similarity"}},
        "components": {"type": "array", "items": {"$ref": "#/$defs/candidateComponent"}}
      }
    },
    "qualificationGates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_traffic", "growth", "positive_score"],
      "properties": {
        "minimum_traffic": {"type": "boolean"},
        "growth": {"type": "boolean"},
        "positive_score": {"type": "boolean"}
      }
    },
    "trendDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_id", "canonical_title", "previous_window_views", "current_window_views", "trend_score", "gates", "outcome", "reasons", "exclusion_reason"],
      "properties": {
        "page_id": {"type": "integer", "minimum": 1},
        "canonical_title": {"type": "string", "minLength": 1},
        "previous_window_views": {"type": "integer", "minimum": 0},
        "current_window_views": {"type": "integer", "minimum": 0},
        "trend_score": {"type": "number"},
        "gates": {"$ref": "#/$defs/qualificationGates"},
        "outcome": {"enum": ["qualified_signal", "classified_signal", "classification_rejected", "failed_qualification", "rejected_noise"]},
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "all_qualification_gates_passed",
              "classification_accepted",
              "classification_rejected:tragedy",
              "classification_rejected:violent_crime",
              "classification_rejected:death_driven",
              "classification_rejected:routine_politics",
              "classification_rejected:isolated_news",
              "classification_rejected:no_consumer_audience",
              "classification_rejected:exhausted_attempts",
              "minimum_traffic_failed",
              "growth_failed",
              "positive_score_failed",
              "main_page",
              "technical_namespace:category",
              "technical_namespace:draft",
              "technical_namespace:file",
              "technical_namespace:help",
              "technical_namespace:media",
              "technical_namespace:mediawiki",
              "technical_namespace:module",
              "technical_namespace:portal",
              "technical_namespace:special",
              "technical_namespace:template",
              "technical_namespace:timedtext",
              "technical_namespace:user",
              "technical_namespace:user talk",
              "technical_namespace:wikipedia"
            ]
          },
          "uniqueItems": true
        },
        "exclusion_reason": {"type": ["string", "null"]}
      }
    },
    "qualifiedSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_id", "canonical_title", "alias_titles", "previous_window_views", "current_window_views", "trend_score"],
      "properties": {
        "page_id": {"type": "integer", "minimum": 1},
        "canonical_title": {"type": "string", "minLength": 1},
        "alias_titles": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "previous_window_views": {"type": "integer", "minimum": 0},
        "current_window_views": {"type": "integer", "minimum": 0},
        "trend_score": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "classificationAttempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt", "raw_output", "validation_valid", "error"],
      "properties": {
        "attempt": {"type": "integer", "minimum": 1, "maximum": 3},
        "raw_output": {},
        "validation_valid": {"type": "boolean"},
        "error": {"type": ["string", "null"]}
      }
    },
    "articleJudgment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supports_consumer_audience", "brand_safe", "rejection_class", "rationale"],
      "properties": {
        "supports_consumer_audience": {"type": "boolean"},
        "brand_safe": {"type": "boolean"},
        "rejection_class": {"enum": ["accepted", "tragedy", "violent_crime", "death_driven", "routine_politics", "isolated_news", "no_consumer_audience"]},
        "rationale": {"type": "string", "minLength": 1}
      }
    },
    "articleClassification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_id", "canonical_title", "prompt", "accepted", "decision_reason", "judgment", "attempts"],
      "properties": {
        "page_id": {"type": "integer", "minimum": 1},
        "canonical_title": {"type": "string", "minLength": 1},
        "prompt": {"type": "string", "minLength": 1},
        "accepted": {"type": "boolean"},
        "decision_reason": {"enum": ["accepted", "tragedy", "violent_crime", "death_driven", "routine_politics", "isolated_news", "no_consumer_audience", "exhausted_attempts"]},
        "judgment": {"oneOf": [{"$ref": "#/$defs/articleJudgment"}, {"type": "null"}]},
        "attempts": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {"$ref": "#/$defs/classificationAttempt"}
        }
      }
    },
    "dailyView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "views"],
      "properties": {
        "date": {"type": "string", "format": "date"},
        "views": {"type": "integer", "minimum": 0}
      }
    },
    "aliasTraffic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_title",
        "previous_window_views",
        "current_window_views",
        "daily_views"
      ],
      "properties": {
        "raw_title": {"type": "string", "minLength": 1},
        "previous_window_views": {"type": "integer", "minimum": 0},
        "current_window_views": {"type": "integer", "minimum": 0},
        "daily_views": {
          "type": "array",
          "minItems": 14,
          "maxItems": 14,
          "items": {"$ref": "#/$defs/dailyView"}
        }
      }
    },
    "canonicalArticle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_id",
        "canonical_title",
        "extract",
        "categories",
        "previous_window_views",
        "current_window_views",
        "aliases"
      ],
      "properties": {
        "page_id": {"type": "integer", "minimum": 1},
        "canonical_title": {"type": "string", "minLength": 1},
        "extract": {"type": "string"},
        "categories": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "previous_window_views": {"type": "integer", "minimum": 0},
        "current_window_views": {"type": "integer", "minimum": 0},
        "aliases": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/aliasTraffic"}
        }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "subject", "attempts", "reason"],
      "properties": {
        "operation": {
          "enum": ["discovery", "pageviews", "metadata", "canonicalization"]
        },
        "subject": {"type": "string", "minLength": 1},
        "attempts": {"type": "integer", "minimum": 1, "maximum": 3},
        "reason": {"type": "string", "minLength": 1}
      }
    }
  }
}
