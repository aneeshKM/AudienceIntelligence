{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audienceintelligence.local/schemas/audit.schema.json",
  "title": "Audience Trend Miner Audit",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "degraded", "run", "decisions", "failures"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "status": {"enum": ["success", "failed"]},
    "degraded": {"type": "boolean"},
    "run": {"type": "object"},
    "decisions": {"type": "array"},
    "failures": {
      "type": "array",
      "items": {"$ref": "#/$defs/failure"}
    },
    "raw_candidate_titles": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "canonical_articles": {
      "type": "array",
      "items": {"$ref": "#/$defs/canonicalArticle"}
    }
  },
  "$defs": {
    "dailyView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "views"],
      "properties": {
        "date": {"type": "string", "format": "date"},
        "views": {"type": "integer", "minimum": 0}
      }
    },
    "aliasTraffic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_title",
        "previous_window_views",
        "current_window_views",
        "daily_views"
      ],
      "properties": {
        "raw_title": {"type": "string", "minLength": 1},
        "previous_window_views": {"type": "integer", "minimum": 0},
        "current_window_views": {"type": "integer", "minimum": 0},
        "daily_views": {
          "type": "array",
          "minItems": 14,
          "maxItems": 14,
          "items": {"$ref": "#/$defs/dailyView"}
        }
      }
    },
    "canonicalArticle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_id",
        "canonical_title",
        "extract",
        "categories",
        "previous_window_views",
        "current_window_views",
        "aliases"
      ],
      "properties": {
        "page_id": {"type": "integer", "minimum": 1},
        "canonical_title": {"type": "string", "minLength": 1},
        "extract": {"type": "string"},
        "categories": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "previous_window_views": {"type": "integer", "minimum": 0},
        "current_window_views": {"type": "integer", "minimum": 0},
        "aliases": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/aliasTraffic"}
        }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "subject", "attempts", "reason"],
      "properties": {
        "operation": {
          "enum": ["discovery", "pageviews", "metadata", "canonicalization"]
        },
        "subject": {"type": "string", "minLength": 1},
        "attempts": {"type": "integer", "minimum": 1, "maximum": 3},
        "reason": {"type": "string", "minLength": 1}
      }
    }
  }
}
