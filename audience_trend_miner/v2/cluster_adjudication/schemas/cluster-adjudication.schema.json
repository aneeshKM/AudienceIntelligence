{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["configuration", "counts", "final_audience_clusters", "rejected_members", "adjudications", "completion"],
  "properties": {
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "framework", "integration", "semantic_audience_formation_fingerprint"],
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "framework": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {"const": "langgraph"},
            "version": {"type": "string", "minLength": 1}
          }
        },
        "integration": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1}
          }
        },
        "semantic_audience_formation_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preliminary_clusters", "final_audience_clusters", "accepted_pages", "rejected_pages"],
      "properties": {
        "preliminary_clusters": {"type": "integer", "minimum": 0},
        "final_audience_clusters": {"type": "integer", "minimum": 0},
        "accepted_pages": {"type": "integer", "minimum": 0},
        "rejected_pages": {"type": "integer", "minimum": 0}
      }
    },
    "final_audience_clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cluster_id", "source_preliminary_cluster_id", "name", "rationale", "members"],
        "properties": {
          "cluster_id": {"type": "string", "minLength": 1},
          "source_preliminary_cluster_id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "rationale": {"type": "string", "minLength": 1},
          "members": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/acceptedMember"}}
        }
      }
    },
    "rejected_members": {
      "type": "array",
      "items": {"$ref": "#/$defs/rejectedMember"}
    },
    "adjudications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["preliminary_cluster_id", "steps", "validation"],
        "properties": {
          "preliminary_cluster_id": {"type": "string", "minLength": 1},
          "steps": {"type": "array", "minItems": 1, "maxItems": 3, "items": {"$ref": "#/$defs/modelStep"}},
          "validation": {"$ref": "#/$defs/validation"}
        }
      }
    },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {"status": {"const": "complete"}}
    }
  },
  "$defs": {
    "acceptedMember": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_id", "canonical_title", "lead", "selected_categories"],
      "properties": {
        "page_id": {"type": "integer"},
        "canonical_title": {"type": "string", "minLength": 1},
        "lead": {"type": "string"},
        "selected_categories": {"type": "array", "maxItems": 5, "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "rejectedMember": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_id", "canonical_title", "reason", "source_preliminary_cluster_id"],
      "properties": {
        "page_id": {"type": "integer"},
        "canonical_title": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "source_preliminary_cluster_id": {"type": "string", "minLength": 1}
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt", "delivery_status", "error"],
      "properties": {
        "attempt": {"type": "integer", "minimum": 1, "maximum": 3},
        "delivery_status": {"enum": ["delivered", "error"]},
        "error": {"type": ["string", "null"]}
      }
    },
    "modelStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "status", "validation_status", "attempts"],
      "properties": {
        "role": {"enum": ["proposer", "critic", "reviser"]},
        "status": {"enum": ["completed", "exhausted"]},
        "validation_status": {"enum": ["valid", "invalid", "not_run"]},
        "attempts": {"type": "array", "minItems": 1, "maxItems": 3, "items": {"$ref": "#/$defs/attempt"}}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "errors"],
      "properties": {
        "status": {"enum": ["valid", "invalid"]},
        "errors": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
